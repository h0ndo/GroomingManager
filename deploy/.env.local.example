# Lokale Entwicklung: Angular und Spring Boot laufen auf dem Host,
# PostgreSQL/Keycloak/Flyway und ein lokaler Nginx-Proxy laufen in Docker.

COMPOSE_PROJECT_NAME=grooming-manager-local
APP_DOMAIN=localhost
APP_PUBLIC_URL=http://localhost:3000
KEYCLOAK_PUBLIC_URL=http://localhost:3000/auth

LOCAL_DEV_HTTP_PORT=3000
LOCAL_DEV_POSTGRES_PORT=5432
LOCAL_FRONTEND_UPSTREAM=host.docker.internal:4200
LOCAL_BACKEND_UPSTREAM=host.docker.internal:8080

KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:latest
FLYWAY_IMAGE=flyway/flyway:10-alpine

# Optionaler lokaler Vision-LLM-Service. Start mit deploy/docker-compose.llm.yml und --profile llm.
LLM_ENABLED=false
LLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# Wenn Backend lokal auf dem Host läuft, nutzt es localhost:8081 statt http://llm:8080.
LLM_BASE_URL=http://localhost:8081
LLM_MODEL=gemma-3-4b-it-qat-q4_0
LLM_HF_REPO=google/gemma-3-4b-it-qat-q4_0-gguf
LLM_HF_FILE=gemma-3-4b-it-q4_0.gguf
# Für Gemma bei Hugging Face Lizenz akzeptieren und Token lokal in deploy/.env.local setzen. Nicht committen.
HF_TOKEN=
LLM_CONTEXT_SIZE=4096
LLM_GPU_LAYERS=999
LLM_VISION_ENABLED=true
LLM_HOST_PORT=8081

POSTGRES_DB=grooming_manager
POSTGRES_USER=grooming_manager
POSTGRES_PASSWORD=local_postgres_password
FLYWAY_URL=jdbc:postgresql://db/grooming_manager

KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=local_keycloak_db_password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=grooming-manager

OIDC_CLIENT_ID=grooming-manager-app
SESSION_SECRET=local_session_secret

# Backend lokal starten mit z.B.:
# SERVER_PORT=8080 \
# DB_HOST=localhost \
# DB_PORT=5432 \
# DB_NAME=grooming_manager \
# DB_USER=grooming_manager \
# DB_PASSWORD=local_postgres_password \
# SPRING_FLYWAY_ENABLED=false \
# OIDC_JWK_SET_URI=http://localhost:3000/auth/realms/grooming-manager/protocol/openid-connect/certs \
# APP_CORS_ALLOWED_ORIGINS=http://localhost:3000 \
# ./mvnw spring-boot:run
