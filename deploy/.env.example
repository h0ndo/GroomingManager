# Kopieren nach deploy/.env und pro Kundeninstanz anpassen.

COMPOSE_PROJECT_NAME=grooming-manager-kunde-demo

# Domain/Subdomain der Kundeninstanz, z.B. kunde-demo.example.de
APP_DOMAIN=grooming-manager-demo.example.de
APP_PUBLIC_URL=https://grooming-manager-demo.example.de
KEYCLOAK_PUBLIC_URL=https://grooming-manager-demo.example.de/auth

# Container/Images der Anwendung. Werden später durch CI/CD gebaut und gepusht.
FRONTEND_IMAGE=grooming-manager-frontend:local
BACKEND_IMAGE=grooming-manager-backend:local

# Für produktive Releases später feste Version pinnen statt latest.
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:latest

# Optionaler lokaler Vision-LLM-Service. Wird nur mit deploy/docker-compose.llm.yml und --profile llm gestartet.
LLM_ENABLED=false
LLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLM_BASE_URL=http://llm:8080
LLM_MODEL=gemma-3-4b-it-qat-q4_0
LLM_HF_REPO=google/gemma-3-4b-it-qat-q4_0-gguf
LLM_HF_FILE=gemma-3-4b-it-q4_0.gguf
# Für Gemma bei Hugging Face Lizenz akzeptieren und Token lokal in deploy/.env setzen. Nicht committen.
HF_TOKEN=
LLM_CONTEXT_SIZE=4096
LLM_GPU_LAYERS=999
LLM_VISION_ENABLED=true
LLM_HOST_PORT=8081

# Ports auf dem Server. Normalerweise unverändert lassen.
HTTP_PORT=80
HTTPS_PORT=443

# App-Datenbank
POSTGRES_DB=grooming_manager
POSTGRES_USER=grooming_manager
POSTGRES_PASSWORD=demo_postgres_password

# Flyway-Migrationen für die App-Datenbank
FLYWAY_IMAGE=flyway/flyway:10-alpine
FLYWAY_URL=jdbc:postgresql://db/grooming_manager

# Keycloak-Datenbank im gleichen Postgres-Container, aber separate DB/User.
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=demo_keycloak_db_password

# Keycloak Admin-Konsole
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=demo_keycloak_admin_password
KEYCLOAK_REALM=grooming-manager

# Public OIDC Client fuer die Angular App. Realm/Client wird per Terraform erzeugt.
OIDC_CLIENT_ID=grooming-manager-app

# App Secrets
SESSION_SECRET=demo_session_secret

# Initialer App-Admin fuer neue Kundeninstanz, falls die App lokale Ersteinrichtung braucht.
INITIAL_ADMIN_EMAIL=admin@example.de
INITIAL_ADMIN_PASSWORD=demo_admin_password
