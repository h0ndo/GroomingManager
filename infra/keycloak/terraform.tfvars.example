# Beispielwerte fuer eine Kundeninstanz.
# Kopieren nach terraform.tfvars und Secrets ersetzen.
# terraform.tfvars darf nicht committed werden.

keycloak_url = "https://grooming-manager-demo.example.de/auth"
keycloak_admin_username = "admin"
keycloak_admin_password = "demo_keycloak_admin_password"

realm = "grooming-manager"
app_url = "https://grooming-manager-demo.example.de"

oidc_client_id = "grooming-manager-app"
# Keycloak-Selbstregistrierung ist für Kund:innen aktiv. E-Mail wird als Benutzername genutzt und muss verifiziert werden.
registration_allowed = true

initial_admin_email = "initial-admin@grooming-manager.local"
initial_admin_password = "demo_admin_password"
initial_admin_first_name = "Admin"
initial_admin_last_name = ""

# Nur fuer lokale Entwicklung / Playwright E2E Tests aktivieren.
# Nicht in produktiven Kundeninstanzen verwenden.
test_users_enabled = false
test_admin_email = "admin@grooming-manager.local"
test_admin_password = "123"
test_groomer_email = "groomer@grooming-manager.local"
test_groomer_password = "123"
test_kunde_email = "kunde@grooming-manager.local"
test_kunde_password = "123"
